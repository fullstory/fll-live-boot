[Unit]
ConditionPathExists=/var/lib/fll/ssh_authorized_keys
Description=Live SSH Access Service
DefaultDependencies=no
Before=shutdown.target
Conflicts=shutdown.target
After=fll-home.service

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=/etc/default/distro
ExecStart=/usr/share/fll-live-initscripts/fll_sshd
Restart=no

[Install]
WantedBy=multi-user.target
