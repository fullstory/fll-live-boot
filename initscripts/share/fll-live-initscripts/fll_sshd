#!/bin/sh
# fll_sshd - provision non-root SSH access to the live user.
#
# Gated by fll-sshd.service (ConditionPathExists=/var/lib/fll/ssh_authorized_keys),
# so this runs only when pyfll baked a public key in via its ssh_authorized_keys=
# option. It installs that key as the live user's authorized_keys and starts
# sshd. Root is out of scope - sshd keeps its PermitRootLogin prohibit-password
# default, and the live media's own sudo/sshstart cover privileged access.
#
# Outcome is reported through the service's exit status: any failed step aborts
# (set -e), marking the unit failed for systemctl status / journalctl -u fll-sshd;
# on success a single breadcrumb line is logged to the journal.

set -e

FLL_LIVE_USER="aptosid"
[ -r /etc/default/distro ] && . /etc/default/distro

KEYSRC="/var/lib/fll/ssh_authorized_keys"
[ -s "${KEYSRC}" ] || exit 0

HOME_DIR="$(getent passwd "${FLL_LIVE_USER}" | cut -d: -f6)"
if [ -z "${HOME_DIR}" ] || [ ! -d "${HOME_DIR}" ]; then
	echo "fll_sshd: no home directory for ${FLL_LIVE_USER}; cannot provision" >&2
	exit 1
fi
GROUP="$(id -gn "${FLL_LIVE_USER}")"

# Install the baked key as the live user's sole authorized_keys (0700/0600).
install -d -m 0700 -o "${FLL_LIVE_USER}" -g "${GROUP}" "${HOME_DIR}/.ssh"
install -m 0600 -o "${FLL_LIVE_USER}" -g "${GROUP}" \
	"${KEYSRC}" "${HOME_DIR}/.ssh/authorized_keys"

# Host keys are generated when openssh-server installs; regenerate any missing
# ones (a no-op otherwise) so sshd can start.
ssh-keygen -A >/dev/null 2>&1

# openssh-server ships on the media but its unit is blacklisted from autostart.
systemctl start ssh

echo "fll_sshd: installed authorized_keys for ${FLL_LIVE_USER}, started sshd"
